{
  "expo": {
    "name": "DiasporaConnect",
    "slug": "diasporaconnect-miabe2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
