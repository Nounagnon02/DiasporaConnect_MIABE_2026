      "backgroundColor": "#FDF8F3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.miabe2026.diasporaconnect",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C75B39"
      },
      "package": "com.miabe2026.diasporaconnect",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen"
    ],
    "newArchEnabled": false
  }
}
