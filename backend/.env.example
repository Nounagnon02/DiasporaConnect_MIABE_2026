# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000

# ── URL publique (ngrok en dev, domaine en prod) ──────────────────────────────
API_URL=https://xxxx.ngrok-free.app

# ── Blockchain Celo ───────────────────────────────────────────────────────────
RPC_URL=https://celo-sepolia.g.alchemy.com/v2/YOUR_KEY
CONTRACT_ADDRESS=0xc7e7a393A3621EAEd1502196a2cF389AeA01CFCB
OPERATOR_PRIVATE_KEY=        # Clé privée du nœud autorisé à appeler release()
OPERATOR_ADDRESS=            # Adresse publique correspondante

# ── CinetPay ──────────────────────────────────────────────────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_ENV=sandbox         # sandbox | production

# ── Taux de change cUSD → FCFA ────────────────────────────────────────────────
EXCHANGE_RATE=612.5

# ── Float ─────────────────────────────────────────────────────────────────────
FLOAT_ALERT_THRESHOLD_FCFA=500000

# ── Webhook secret ────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change_me_in_production
